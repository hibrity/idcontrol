<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Idcontrol • Portaria</title>

  <script type="module">
    import { createClient } from "https://esm.sh/@supabase/supabase-js@2";
    window.supabase = createClient(
      "https://zbxrpprwjrholrycwsqa.supabase.co",
      "sb_publishable_c4O2UN_u487qWsu4TNwG0Q_OGj3aHNM"
    );
  </script>

  <script src="https://unpkg.com/html5-qrcode"></script>

  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #0f172a;
      color: white;
    }

    .wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 16px;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 16px;
    }

    .title {
      font-size: 24px;
      font-weight: bold;
    }

    .subtitle {
      color: #cbd5e1;
      font-size: 14px;
      margin-top: 4px;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
      gap: 16px;
    }

    .stack {
      display: grid;
      gap: 16px;
    }

    .card {
      background: #1e293b;
      border-radius: 14px;
      padding: 18px;
    }

    .card h3 {
      margin-top: 0;
      margin-bottom: 12px;
      font-size: 18px;
    }

    .item {
      background: #0b1220;
      padding: 12px;
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,.06);
      margin-top: 10px;
    }

    .muted {
      color: #cbd5e1;
      font-size: 14px;
    }

    .stats {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
    }

    .stat {
      background: #0b1220;
      border-radius: 12px;
      padding: 14px;
      border: 1px solid rgba(255,255,255,.06);
    }

    .stat strong {
      display: block;
      font-size: 22px;
      margin-top: 6px;
    }

    .row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }

    .row > * {
      flex: 1;
      min-width: 130px;
    }

    input, select, textarea {
      width: 100%;
      padding: 11px 12px;
      border: none;
      border-radius: 8px;
      margin-top: 8px;
      margin-bottom: 10px;
      background: white;
      color: black;
    }

    textarea {
      min-height: 90px;
      resize: vertical;
    }

    button, a.btn {
      display: inline-block;
      padding: 10px 14px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      text-decoration: none;
    }

    .primary {
      background: #22c55e;
      color: black;
    }

    .ghost {
      background: #334155;
      color: white;
    }

    .danger {
      background: #ef4444;
      color: white;
    }

    .badge {
      display: inline-block;
      padding: 4px 8px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: bold;
      margin-top: 6px;
      background: #22c55e;
      color: black;
    }

    .warning {
      background: #f59e0b;
      color: black;
    }

    .danger-badge {
      background: #ef4444;
      color: white;
    }

    #qr-reader {
      width: 100%;
      border-radius: 10px;
      overflow: hidden;
      background: black;
    }

    #qr-result {
      margin-top: 12px;
    }

    .section-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: 10px;
    }

    @media (max-width: 900px) {
      .grid {
        grid-template-columns: 1fr;
      }

      .stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 540px) {
      .stats {
        grid-template-columns: 1fr;
      }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="topbar">
      <div>
        <div class="title">Portaria • Idcontrol</div>
        <div class="subtitle">Operação rápida de acesso, visitantes, QR e monitoramento.</div>
      </div>

      <div class="row" style="max-width:420px; width:100%;">
        <a class="btn ghost" href="./index.html">← Painel completo</a>
        <button class="danger" onclick="logout()">Sair</button>
      </div>
    </div>

    <div class="card">
      <h3>Resumo rápido</h3>
      <div class="stats" id="stats"></div>
    </div>

    <div class="grid">
      <div class="stack">
        <div class="card">
          <h3>Registrar visitante rápido</h3>

          <input id="visitor_name" placeholder="Nome do visitante" />
          <input id="visitor_document" placeholder="Documento" />
          <input id="visitor_host" placeholder="Responsável / unidade / setor" />

          <div class="section-actions">
            <button class="primary" onclick="saveVisitorQuick()">Cadastrar visitante</button>
          </div>

          <div id="visitor_result"></div>
        </div>

        <div class="card">
          <h3>Registrar acesso manual</h3>

          <select id="access_target_type" onchange="toggleTargetType()">
            <option value="person">Pessoa</option>
            <option value="visitor">Visitante</option>
          </select>

          <select id="access_person"></select>
          <select id="access_visitor" style="display:none"></select>

          <div class="row">
            <select id="access_type">
              <option value="entry">Entrada</option>
              <option value="exit">Saída</option>
            </select>

            <input id="access_location" placeholder="Local" />
          </div>

          <textarea id="access_notes" placeholder="Observações"></textarea>

          <div class="section-actions">
            <button class="primary" onclick="saveAccess()">Registrar acesso</button>
          </div>

          <div id="manual_access_result"></div>
        </div>

        <div class="card">
          <h3>Leitor QR / Código manual</h3>
          <p class="muted">Aponte a câmera para o QR ou digite o código.</p>

          <div id="qr-reader"></div>
          <div id="qr-result"></div>

          <hr style="margin:18px 0;border:0;border-top:1px solid #334155">

          <input id="manual_tag_code" placeholder="Digite o código da tag ou QR" />
          <div class="section-actions">
            <button class="primary" onclick="submitManualTag()">Registrar por código</button>
          </div>
        </div>
      </div>

      <div class="stack">
        <div class="card">
          <h3>Quem está dentro agora</h3>
          <div id="inside_list"></div>
        </div>

        <div class="card">
          <h3>Últimos acessos</h3>
          <div id="access_list"></div>
        </div>

        <div class="card">
          <h3>Visitantes recentes</h3>
          <div id="visitors_list"></div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let qrScanner = null;
    let qrRunning = false;
    let currentUserRole = null;

    async function getUser() {
      const { data } = await supabase.auth.getUser();
      return data.user;
    }

    async function ensureSession() {
      const { data } = await supabase.auth.getSession();
      if (!data.session) {
        location.href = "./index.html";
        return false;
      }
      return true;
    }

    async function logout() {
      await stopQRScanner();
      await supabase.auth.signOut();
      location.href = "./index.html";
    }

    async function getCurrentOrganizationId() {
      const { data, error } = await supabase
        .from("organization_users")
        .select("organization_id")
        .limit(1)
        .single();

      if (error) {
        console.error("Erro ao buscar organization_id:", error.message);
        return null;
      }

      return data.organization_id;
    }

    async function getCurrentUserRole() {
      const { data, error } = await supabase
        .from("organization_users")
        .select("role")
        .limit(1)
        .single();

      if (error) {
        console.error("Erro ao buscar role:", error.message);
        return null;
      }

      currentUserRole = data.role;
      return data.role;
    }

    function canOperateAccess() {
      return currentUserRole === "admin" || currentUserRole === "porteiro" || currentUserRole === "seguranca";
    }

    function canRegisterVisitors() {
      return currentUserRole === "admin" || currentUserRole === "porteiro" || currentUserRole === "gestor";
    }

    function toggleTargetType() {
      const type = document.getElementById("access_target_type").value;
      const personSelect = document.getElementById("access_person");
      const visitorSelect = document.getElementById("access_visitor");

      if (type === "person") {
        personSelect.style.display = "block";
        visitorSelect.style.display = "none";
      } else {
        personSelect.style.display = "none";
        visitorSelect.style.display = "block";
      }
    }

    async function addHistory(title, description) {
      const user = await getUser();
      const organizationId = await getCurrentOrganizationId();
      if (!user || !organizationId) return;

      await supabase.from("history").insert({
        title,
        description,
        created_by: user.id,
        organization_id: organizationId
      });
    }

    async function loadPeople() {
      const { data, error } = await supabase
        .from("people")
        .select("id, full_name")
        .order("full_name", { ascending: true });

      const accessSelect = document.getElementById("access_person");
      accessSelect.innerHTML = "";

      if (error || !data || data.length === 0) {
        accessSelect.innerHTML = `<option value="">Nenhuma pessoa</option>`;
        return;
      }

      data.forEach(p => {
        accessSelect.innerHTML += `<option value="${p.id}">${p.full_name}</option>`;
      });
    }

    async function loadVisitors() {
      const { data, error } = await supabase
        .from("visitors")
        .select("*")
        .order("created_at", { ascending: false })
        .limit(10);

      const list = document.getElementById("visitors_list");
      const accessSelect = document.getElementById("access_visitor");

      list.innerHTML = "";
      accessSelect.innerHTML = "";

      if (error) {
        list.innerHTML = `<div class="item">Erro ao carregar visitantes</div>`;
        accessSelect.innerHTML = `<option value="">Nenhum visitante</option>`;
        return;
      }

      if (!data || data.length === 0) {
        list.innerHTML = `<div class="item">Nenhum visitante recente</div>`;
        accessSelect.innerHTML = `<option value="">Nenhum visitante</option>`;
        return;
      }

      data.forEach(v => {
        list.innerHTML += `
          <div class="item">
            <b>${v.full_name}</b><br>
            Documento: ${v.document || "-"}<br>
            Responsável: ${v.host_name || "-"}
          </div>
        `;
        accessSelect.innerHTML += `<option value="${v.id}">${v.full_name}</option>`;
      });
    }

    async function saveVisitorQuick() {
      if (!canRegisterVisitors()) {
        alert("Você não tem permissão para cadastrar visitantes.");
        return;
      }

      const user = await getUser();
      const organizationId = await getCurrentOrganizationId();
      if (!user || !organizationId) return;

      const name = document.getElementById("visitor_name").value.trim();
      const doc = document.getElementById("visitor_document").value.trim();
      const host = document.getElementById("visitor_host").value.trim();
      const box = document.getElementById("visitor_result");

      if (!name) {
        alert("Nome obrigatório");
        return;
      }

      const { error } = await supabase.from("visitors").insert({
        full_name: name,
        document: doc,
        host_name: host,
        status: "pending",
        created_by: user.id,
        organization_id: organizationId
      });

      if (error) {
        box.innerHTML = `<div class="item">Erro: ${error.message}</div>`;
        return;
      }

      await addHistory("Visitante cadastrado", `${name} foi cadastrado rapidamente pela portaria.`);

      document.getElementById("visitor_name").value = "";
      document.getElementById("visitor_document").value = "";
      document.getElementById("visitor_host").value = "";

      box.innerHTML = `<div class="item"><b>Visitante cadastrado com sucesso.</b></div>`;

      await loadVisitors();
      await loadStats();
    }

    async function saveAccess() {
      if (!canOperateAccess()) {
        alert("Você não tem permissão para registrar acessos.");
        return;
      }

      const user = await getUser();
      const organizationId = await getCurrentOrganizationId();
      if (!user || !organizationId) return;

      const targetType = document.getElementById("access_target_type").value;
      const personId = document.getElementById("access_person").value;
      const visitorId = document.getElementById("access_visitor").value;
      const type = document.getElementById("access_type").value;
      const location = document.getElementById("access_location").value.trim();
      const notes = document.getElementById("access_notes").value.trim();
      const box = document.getElementById("manual_access_result");

      if (targetType === "person" && !personId) {
        alert("Selecione uma pessoa");
        return;
      }

      if (targetType === "visitor" && !visitorId) {
        alert("Selecione um visitante");
        return;
      }

      const payload = {
        access_type: type,
        location_name: location || null,
        notes: notes || null,
        method: "manual",
        created_by: user.id,
        organization_id: organizationId,
        person_id: targetType === "person" ? personId : null,
        visitor_id: targetType === "visitor" ? visitorId : null
      };

      const { error } = await supabase.from("access_logs").insert(payload);

      if (error) {
        box.innerHTML = `<div class="item">Erro: ${error.message}</div>`;
        return;
      }

      await addHistory(
        "Acesso registrado",
        `${type === "entry" ? "Entrada" : "Saída"} registrada pela portaria.`
      );

      document.getElementById("access_location").value = "";
      document.getElementById("access_notes").value = "";

      box.innerHTML = `<div class="item"><b>Acesso registrado com sucesso.</b></div>`;

      await loadAccess();
      await loadInside();
      await loadStats();
    }

    async function registerAccessByTag(tagCode) {
      if (!canOperateAccess()) {
        alert("Você não tem permissão para operar QR/código.");
        return;
      }

      const user = await getUser();
      const organizationId = await getCurrentOrganizationId();
      if (!user || !organizationId) return;

      const { data: tag, error: tagError } = await supabase
        .from("tags")
        .select("*")
        .eq("code", tagCode)
        .eq("active", true)
        .single();

      if (tagError || !tag) {
        document.getElementById("qr-result").innerHTML = `
          <div class="item">
            <b>Código não encontrado</b><br>
            ${tagCode}<br>
            <span class="badge danger-badge">Falha</span>
          </div>
        `;
        return;
      }

      const { error } = await supabase.from("access_logs").insert({
        created_by: user.id,
        organization_id: organizationId,
        person_id: tag.person_id,
        visitor_id: tag.visitor_id,
        access_type: "entry",
        method: "tag",
        location_name: "Portaria / QR",
        notes: `Leitura da tag ${tagCode}`
      });

      if (error) {
        document.getElementById("qr-result").innerHTML = `<div class="item">Erro ao registrar acesso: ${error.message}</div>`;
        return;
      }

      await addHistory("Acesso por QR/tag", `Código ${tagCode} validado na portaria.`);

      document.getElementById("qr-result").innerHTML = `
        <div class="item">
          <b>Acesso registrado com sucesso</b><br>
          Código: ${tagCode}<br>
          <span class="badge">Entrada liberada</span>
        </div>
      `;

      await loadAccess();
      await loadInside();
      await loadStats();
    }

    async function submitManualTag() {
      const code = document.getElementById("manual_tag_code").value.trim();

      if (!code) {
        alert("Digite um código.");
        return;
      }

      document.getElementById("qr-result").innerHTML = `<div class="item">Processando código: <b>${code}</b></div>`;
      await registerAccessByTag(code);
      document.getElementById("manual_tag_code").value = "";
    }

    async function loadAccess() {
      const { data, error } = await supabase
        .from("access_logs")
        .select("*")
        .order("created_at", { ascending: false })
        .limit(12);

      const list = document.getElementById("access_list");
      list.innerHTML = "";

      if (error) {
        list.innerHTML = `<div class="item">Erro ao carregar acessos</div>`;
        return;
      }

      if (!data || data.length === 0) {
        list.innerHTML = `<div class="item">Nenhum acesso recente</div>`;
        return;
      }

      data.forEach(a => {
        list.innerHTML += `
          <div class="item">
            <b>${a.access_type === "entry" ? "Entrada" : "Saída"}</b><br>
            Método: ${a.method || "-"}<br>
            Local: ${a.location_name || "-"}<br>
            Observações: ${a.notes || "-"}
          </div>
        `;
      });
    }

    async function loadInside() {
      const insideList = document.getElementById("inside_list");
      insideList.innerHTML = "";

      const { data: accessData, error } = await supabase
        .from("access_logs")
        .select("*")
        .order("created_at", { ascending: false });

      if (error) {
        insideList.innerHTML = `<div class="item">Erro ao carregar presença atual</div>`;
        return;
      }

      const latestByTarget = {};

      (accessData || []).forEach(a => {
        const key = a.person_id ? `person_${a.person_id}` : `visitor_${a.visitor_id}`;
        if (!latestByTarget[key]) latestByTarget[key] = a;
      });

      const present = Object.values(latestByTarget).filter(a => a.access_type === "entry");

      if (present.length === 0) {
        insideList.innerHTML = `<div class="item">Ninguém está dentro no momento</div>`;
        return;
      }

      const personIds = present.filter(x => x.person_id).map(x => x.person_id);
      const visitorIds = present.filter(x => x.visitor_id).map(x => x.visitor_id);

      const peopleMap = {};
      const visitorsMap = {};

      if (personIds.length) {
        const { data: peopleData } = await supabase.from("people").select("id, full_name").in("id", personIds);
        (peopleData || []).forEach(p => peopleMap[p.id] = p.full_name);
      }

      if (visitorIds.length) {
        const { data: visitorData } = await supabase.from("visitors").select("id, full_name").in("id", visitorIds);
        (visitorData || []).forEach(v => visitorsMap[v.id] = v.full_name);
      }

      present.forEach(a => {
        const name = a.person_id ? peopleMap[a.person_id] : visitorsMap[a.visitor_id];
        const kind = a.person_id ? "Pessoa" : "Visitante";

        insideList.innerHTML += `
          <div class="item">
            <b>${name || "Registro"}</b><br>
            ${kind}<br>
            Local: ${a.location_name || "-"}<br>
            <span class="badge">Dentro</span>
          </div>
        `;
      });
    }

    async function loadStats() {
      const peopleRes = await supabase.from("people").select("*", { count: "exact", head: true });
      const visitorsRes = await supabase.from("visitors").select("*", { count: "exact", head: true });
      const accessRes = await supabase.from("access_logs").select("*", { count: "exact", head: true });
      const tagsRes = await supabase.from("tags").select("*", { count: "exact", head: true });

      const { data: accessData } = await supabase
        .from("access_logs")
        .select("*")
        .order("created_at", { ascending: false });

      const latestByTarget = {};
      (accessData || []).forEach(a => {
        const key = a.person_id ? `person_${a.person_id}` : `visitor_${a.visitor_id}`;
        if (!latestByTarget[key]) latestByTarget[key] = a;
      });

      const insideCount = Object.values(latestByTarget).filter(a => a.access_type === "entry").length;

      document.getElementById("stats").innerHTML = `
        <div class="stat">
          Pessoas
          <strong>${peopleRes.count || 0}</strong>
        </div>
        <div class="stat">
          Visitantes
          <strong>${visitorsRes.count || 0}</strong>
        </div>
        <div class="stat">
          Acessos
          <strong>${accessRes.count || 0}</strong>
        </div>
        <div class="stat">
          Dentro agora
          <strong>${insideCount}</strong>
        </div>
      `;
    }

    async function startQRScanner() {
      if (qrRunning) return;

      try {
        if (!qrScanner) {
          qrScanner = new Html5Qrcode("qr-reader");
        }

        await qrScanner.start(
          { facingMode: "environment" },
          { fps: 10, qrbox: 250 },
          async (decodedText) => {
            document.getElementById("qr-result").innerHTML = `<div class="item">QR detectado: <b>${decodedText}</b></div>`;
            await stopQRScanner();
            await registerAccessByTag(decodedText);
          },
          () => {}
        );

        qrRunning = true;
      } catch (err) {
        document.getElementById("qr-result").innerHTML = `<div class="item">Erro ao iniciar câmera. Verifique a permissão.</div>`;
      }
    }

    async function stopQRScanner() {
      if (qrScanner && qrRunning) {
        try {
          await qrScanner.stop();
          await qrScanner.clear();
        } catch (e) {}
        qrRunning = false;
      }
    }

    async function init() {
      document.getElementById("app").style.display = "block";

      await getCurrentUserRole();

      if (!canOperateAccess() && !canRegisterVisitors()) {
        alert("Seu perfil não tem acesso ao modo portaria.");
        location.href = "./index.html";
        return;
      }

      await loadPeople();
      await loadVisitors();
      await loadAccess();
      await loadInside();
      await loadStats();

      toggleTargetType();
      await startQRScanner();
    }

    (async () => {
      const ok = await ensureSession();
      if (!ok) return;
      await init();
    })();

    window.logout = logout;
    window.saveVisitorQuick = saveVisitorQuick;
    window.saveAccess = saveAccess;
    window.submitManualTag = submitManualTag;
    window.toggleTargetType = toggleTargetType;
    window.startQRScanner = startQRScanner;
  </script>
</body>
</html>